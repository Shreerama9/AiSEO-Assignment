# Environment Variables for AEGIS — AEO & GEO Content Intelligence Platform
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The application loads .env automatically at startup (via python-dotenv).
# Never commit your actual .env file — it is in .gitignore.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# OpenAI API key — used by POST /api/fanout/generate and POST /api/fanout/stream
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Optional — override defaults
# ---------------------------------------------------------------------------

# LLM model used for fan-out query generation (default: gpt-4o-mini)
# FANOUT_LLM_MODEL=gpt-4o-mini

# Similarity threshold for gap coverage detection (default: 0.72)
# SIMILARITY_THRESHOLD=0.72

# Number of LLM retry attempts on malformed output (default: 3)
# LLM_MAX_RETRIES=3

# URL cache TTL in seconds (default: 3600 = 1 hour)
# URL_CACHE_TTL=3600
